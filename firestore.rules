rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Helper Functions (Phase 3)
    // ===============================================================
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isAdmin() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
             (request.auth.token.email == "akhathuto@gmail.com" && request.auth.token.email_verified == true);
    }

    function isValidEmail(email) {
      return email is string && email.matches('^[^@]+@[^@]+\\.[a-zA-Z]{2,}$');
    }

    // ===============================================================
    // Validation Blueprints (The "Anti-Update-Gap")
    // ===============================================================

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'createdAt', 'onboarded']) &&
             data.uid == request.auth.uid &&
             data.email is string &&
             data.createdAt is timestamp &&
             data.onboarded is bool &&
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 500)) &&
             (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() <= 4096)) &&
             (!('role' in data) || (data.role is string && data.role in ['student', 'teacher', 'business_owner', 'normal_user', 'employee', ''])) &&
             (!('grade' in data) || (data.grade is string && data.grade.size() <= 200) || data.grade == null) &&
             (!('school' in data) || (data.school is string && data.school.size() <= 500) || data.school == null);
    }

    function isValidHistoryEntry(data) {
      return data.keys().hasAll(['id', 'expression', 'result', 'timestamp', 'isFavorite', 'userId']) &&
             data.keys().size() == 6 &&
             data.id is string && data.id.size() <= 100 &&
             data.expression is string && data.expression.size() <= 5000 &&
             data.result is string && data.result.size() <= 5000 &&
             data.timestamp is number &&
             data.isFavorite is bool &&
             data.userId == request.auth.uid;
    }

    function isValidNote(data) {
      return data.keys().hasAll(['title', 'content', 'userId', 'updatedAt']) &&
             data.keys().size() == 4 &&
             data.title is string && data.title.size() <= 200 &&
             data.content is string && data.content.size() <= 50000 &&
             data.userId == request.auth.uid &&
             data.updatedAt in [request.time, serverTimestamp()]; // Using request.time or serverTimestamp()
    }

    function isValidContactMessage(data) {
      return data.keys().hasAll(['name', 'email', 'subject', 'message', 'createdAt', 'status']) &&
             data.keys().size() == 6 &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.email is string && isValidEmail(data.email) &&
             data.subject is string && data.subject.size() > 0 && data.subject.size() <= 200 &&
             data.message is string && data.message.size() > 0 && data.message.size() <= 10000 &&
             data.createdAt == request.time &&
             data.status in ['new', 'read', 'replied'];
    }

    function isValidFeedback(data) {
       return data.keys().hasAll(['rating', 'category', 'experience', 'usefulFeatures', 'improvement', 'missingTools', 'createdAt', 'userId']) &&
              data.rating is number && data.rating >= 0 && data.rating <= 5 &&
              data.category is string &&
              data.experience is string &&
              data.usefulFeatures is string &&
              data.improvement is string &&
              data.missingTools is string &&
              data.createdAt == request.time &&
              (data.userId == null || data.userId == request.auth.uid);
    }

    function isValidStats(data) {
      return data.keys().hasAll(['totalScholars', 'lastUpdated']) &&
             data.totalScholars is number &&
             data.lastUpdated == request.time;
    }

    // ===============================================================
    // Match Blocks (The Fortress)
    // ===============================================================

    match /stats/globals {
      allow read: if true; // Publicly readable
      allow create: if isAdmin() || (isSignedIn() && isValidStats(incoming()) && incoming().totalScholars <= 100); 
      allow update: if isAdmin() || (
        isSignedIn() && 
        isValidStats(incoming()) && 
        incoming().totalScholars == existing().totalScholars + 1 &&
        incoming().diff(existing()).affectedKeys().hasOnly(['totalScholars', 'lastUpdated'])
      );
      allow delete: if isAdmin();
    }

    match /feedback/{feedbackId} {
      allow get, list: if isAdmin();
      allow create: if isValidId(feedbackId) && isValidFeedback(incoming());
      allow update, delete: if isAdmin();
    }

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && isValidUser(incoming()) && incoming().createdAt == request.time;
      allow update: if isOwner(userId) && isValidUser(incoming()) && (
        // Action: Standard Update
        (incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'role', 'grade', 'school', 'onboarded']))
      );
      allow delete: if isAdmin();
    }

    match /history/{entryId} {
      allow get: if isSignedIn() && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(entryId) && isValidHistoryEntry(incoming());
      allow update: if isSignedIn() && existing().userId == request.auth.uid && isValidHistoryEntry(incoming()) && (
        (incoming().diff(existing()).affectedKeys().hasOnly(['isFavorite']))
      );
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }

    match /notes/{noteId} {
      allow get: if isSignedIn() && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(noteId) && isValidNote(incoming());
      allow update: if isSignedIn() && existing().userId == request.auth.uid && isValidNote(incoming()) && (
        (incoming().diff(existing()).affectedKeys().hasOnly(['title', 'content', 'updatedAt']))
      );
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }

    match /contact_messages/{messageId} {
      allow get, list: if isAdmin();
      allow create: if isValidId(messageId) && isValidContactMessage(incoming()) && incoming().status == 'new';
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
  }
}
