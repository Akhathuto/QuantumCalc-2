{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user profile",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "User ID" },
        "email": { "type": "string", "format": "email", "description": "User email" },
        "displayName": { "type": "string", "description": "User display name" },
        "photoURL": { "type": "string", "description": "User photo URL" },
        "role": { "type": "string", "enum": ["student", "teacher", "business_owner", "normal_user", "employee"], "description": "User role" },
        "grade": { "type": "string", "description": "Grade or level (for students/teachers)" },
        "school": { "type": "string", "description": "School or organization" },
        "onboarded": { "type": "boolean", "description": "Whether the user has completed onboarding" },
        "createdAt": { "type": "timestamp", "description": "Account creation time" },
        "dailyGoal": {
          "type": "object",
          "description": "Daily calculation goal, history, and streak sync",
          "properties": {
            "target": { "type": "number" },
            "streak": { "type": "number" },
            "history": { "type": "object" }
          }
        }
      },
      "required": ["uid", "email", "createdAt", "onboarded"]
    },
    "HistoryEntry": {
      "title": "HistoryEntry",
      "description": "A calculation history entry",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "expression": { "type": "string" },
        "result": { "type": "string" },
        "timestamp": { "type": "number" },
        "isFavorite": { "type": "boolean" },
        "userId": { "type": "string" }
      },
      "required": ["id", "expression", "result", "timestamp", "isFavorite", "userId"]
    },
    "Settings": {
      "title": "Settings",
      "description": "User preferences",
      "type": "object",
      "properties": {
        "theme": { "type": "string", "enum": ["light", "dark", "system"] },
        "defaultCalculator": { "type": "string" },
        "userId": { "type": "string" }
      },
      "required": ["userId"]
    },
    "ContactMessage": {
      "title": "ContactMessage",
      "description": "A message submitted via the contact form",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "subject": { "type": "string" },
        "message": { "type": "string" },
        "createdAt": { "type": "timestamp" },
        "status": { "type": "string", "enum": ["new", "read", "replied"] }
      },
      "required": ["name", "email", "subject", "message", "createdAt", "status"]
    },
    "Note": {
      "title": "Note",
      "description": "A personal scratchpad note",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "userId": { "type": "string" },
        "updatedAt": { "type": "timestamp" }
      },
      "required": ["title", "content", "userId", "updatedAt"]
    },
    "Stats": {
      "title": "Stats",
      "description": "Global application statistics",
      "type": "object",
      "properties": {
        "totalScholars": { "type": "number", "description": "Total number of registered users" },
        "lastUpdated": { "type": "timestamp" }
      },
      "required": ["totalScholars", "lastUpdated"]
    },
    "Share": {
      "title": "Share",
      "description": "A shared calculation state",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string" },
        "title": { "type": "string" },
        "expression": { "type": "string" },
        "result": { "type": "string" },
        "stateData": { "type": "string" },
        "createdAt": { "type": "timestamp" },
        "userId": { "type": "string" }
      },
      "required": ["id", "type", "title", "expression", "result", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "/stats/globals": {
      "schema": { "$ref": "#/entities/Stats" },
      "description": "Global application stats"
    },
    "/history/{entryId}": {
      "schema": { "$ref": "#/entities/HistoryEntry" },
      "description": "User calculation history"
    },
    "/settings/{userId}": {
      "schema": { "$ref": "#/entities/Settings" },
      "description": "User settings"
    },
    "/contact_messages/{messageId}": {
      "schema": { "$ref": "#/entities/ContactMessage" },
      "description": "Contact form submissions"
    },
    "/notes/{noteId}": {
      "schema": { "$ref": "#/entities/Note" },
      "description": "User notes"
    },
    "/shares/{shareId}": {
      "schema": { "$ref": "#/entities/Share" },
      "description": "Shared calculation payloads"
    }
  }
}
