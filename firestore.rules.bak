rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - displayName: string (optional)
    //   - photoURL: string (optional)
    //   - createdAt: timestamp (required)
    //
    // Collection: history
    // Document ID: {entryId}
    // Fields:
    //   - id: string (required)
    //   - expression: string (required)
    //   - result: string (required)
    //   - timestamp: number (required)
    //   - isFavorite: boolean (required)
    //   - userId: string (required)
    //
    // Collection: settings
    // Document ID: {userId}
    // Fields:
    //   - theme: string (optional)
    //   - defaultCalculator: string (optional)
    //   - userId: string (required)
    //
    // Collection: contact_messages
    // Document ID: {messageId}
    // Fields:
    //   - name: string (required)
    //   - email: string (required)
    //   - subject: string (required)
    //   - message: string (required)
    //   - createdAt: timestamp (required)
    //   - status: string (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }

    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }

    function userIdUnchanged() {
      return !('userId' in request.resource.data) || request.resource.data.userId == request.auth.uid;
    }

    function userIdNotModified() {
      return !('userId' in request.resource.data) || request.resource.data.userId == resource.data.userId;
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidEmail(email) {
      return email is string && email.matches("^[^@]+@[^@]+\\.[a-zA-Z]{2,}$");
    }

    function isAdmin() {
      return isAuthenticated() && (request.auth.token.email == "akhathuto@gmail.com" || request.auth.token.email == "akha.thuto@gmail.com") && request.auth.token.email_verified == true;
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidUser(data) {
      return hasOnlyAllowedFields(['uid', 'email', 'displayName', 'photoURL', 'role', 'grade', 'school', 'onboarded', 'createdAt']) &&
             data.uid is string &&
             data.email is string && isValidEmail(data.email) &&
             data.createdAt is timestamp &&
             data.onboarded is bool &&
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() < 100)) &&
             (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() < 2048)) &&
             (!('role' in data) || (data.role is string && data.role in ['student', 'teacher', 'business_owner', 'normal_user', 'employee'])) &&
             (!('grade' in data) || (data.grade is string && data.grade.size() < 50)) &&
             (!('school' in data) || (data.school is string && data.school.size() < 200));
    }

    function isValidHistoryEntry(data) {
      return hasOnlyAllowedFields(['id', 'expression', 'result', 'timestamp', 'isFavorite', 'userId']) &&
             data.id is string && data.id.size() < 100 &&
             data.expression is string && data.expression.size() < 1000 &&
             data.result is string && data.result.size() < 1000 &&
             data.timestamp is number &&
             data.isFavorite is bool &&
             data.userId is string && data.userId == request.auth.uid;
    }

    function isValidSettings(data) {
      return hasOnlyAllowedFields(['theme', 'defaultCalculator', 'userId']) &&
             data.userId is string && data.userId == request.auth.uid &&
             (!('theme' in data) || (data.theme is string && data.theme in ['light', 'dark', 'system'])) &&
             (!('defaultCalculator' in data) || (data.defaultCalculator is string && data.defaultCalculator.size() < 50));
    }

    function isValidContactMessage(data) {
      return hasOnlyAllowedFields(['name', 'email', 'subject', 'message', 'createdAt', 'status']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.email is string && isValidEmail(data.email) &&
             data.subject is string && data.subject.size() > 0 && data.subject.size() < 200 &&
             data.message is string && data.message.size() > 0 && data.message.size() < 5000 &&
             data.createdAt is timestamp &&
             data.status in ['new', 'read', 'replied'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /test/connection {
      allow read: if true;
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) && uidUnchanged();
      allow update: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) && uidNotModified() && request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isOwner(userId) || isAdmin();
    }

    match /history/{entryId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && isValidHistoryEntry(request.resource.data) && userIdUnchanged();
      allow update: if isAuthenticated() && isDocOwner() && isValidHistoryEntry(request.resource.data) && userIdNotModified();
      allow delete: if isDocOwner() || isAdmin();
    }

    match /settings/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isOwner(userId) && isValidSettings(request.resource.data) && userIdUnchanged();
      allow update: if isAuthenticated() && isOwner(userId) && isValidSettings(request.resource.data) && userIdNotModified();
      allow delete: if isOwner(userId) || isAdmin();
    }

    match /contact_messages/{messageId} {
      allow read: if isAdmin();
      allow create: if isValidContactMessage(request.resource.data) && request.resource.data.status == 'new';
      allow update: if isAdmin() && isValidContactMessage(request.resource.data);
      allow delete: if isAdmin();
    }

    match /notes/{noteId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && isDocOwner() && request.resource.data.userId == resource.data.userId;
      allow delete: if isDocOwner() || isAdmin();
    }
  }
}
